# ══════════════════════════════════════════════════
# WhaleX Prime Core v3 — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# ══════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────
# 1. اذهب لـ @BotFather في تيليجرام
# 2. اكتب /newbot واتبع الخطوات
# 3. انسخ التوكن هنا
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# قناة الإشارات — ضع @username أو Chat ID سالب مثل -1001234567890
TELEGRAM_CHANNEL_ID=@YourSignalsChannel

# Chat ID الخاص بك لاستقبال تنبيهات النظام
# اكتب لـ @userinfobot في تيليجرام لمعرفته
TELEGRAM_ADMIN_CHAT_ID=123456789

# رابط السيرفر الخاص بك (بدون / في النهاية)
# مثال: https://yourdomain.com أو http://1.2.3.4:8000
TELEGRAM_MINI_APP_URL=https://yourdomain.com/

# ── Anthropic AI ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── App Security ─────────────────────────────────
APP_SECRET_KEY=ضع-كلمة-سرية-طويلة-وعشوائية-هنا
GAS_FEE_PCT=0.01

# ── RPC Endpoints (اختياري — القيم الافتراضية مجانية) ─
# SOLANA_RPC_URL=https://your-private-solana-rpc
# ETHEREUM_RPC_URL=https://your-alchemy-url
# BSC_RPC_URL=https://your-bsc-rpc
